ORACLE_IMAGE=container-registry.oracle.com/database/free
ORACLE_IMAGE_TAG=23.26.2.0
ORACLE_PWD=Oracle_26ai_Demo_2026
APP_USER=SEMCACHE_APP
APP_PASSWORD=SemCache_26ai_Demo
PRIMARY_HOST_PORT=15210
TRUE_CACHE_HOST_PORT=15220
PRIMARY_JDBC_URL=jdbc:oracle:thin:@//localhost:15210/FREEPDB1
TRUE_CACHE_JDBC_URL=jdbc:oracle:thin:@//localhost:15220/semcache_pdb_tc
SEM_CACHE_READ_ROUTE=true-cache
SEM_CACHE_PROVIDER=mock
SEM_CACHE_THRESHOLD=0.10

# Full benchmark settings. Leave OPENAI_API_KEY out of committed files;
# export it in your shell or keep it in a private local .env.
BENCHMARK_PROVIDER_MODE=openai
BENCHMARK_REQUESTS=1000
BENCHMARK_WORKLOAD_FAMILIES=50
BENCHMARK_CONCURRENCY=1
BENCHMARK_PREWARM_PAUSE_MS=1500
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_MAX_OUTPUT_TOKENS=80
OPENAI_INPUT_COST_PER_MILLION=0.15
OPENAI_OUTPUT_COST_PER_MILLION=0.60
